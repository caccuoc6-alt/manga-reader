# ─────────────────────────────────────────────────────────────────
# manga-reader — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git (it's already in .gitignore).
# ─────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Cloudinary ───────────────────────────────────────────────────
# Get from: https://console.cloudinary.com → Dashboard → API Keys
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>

# ── Auth (for your Express server) ───────────────────────────────
SESSION_SECRET=change-me-to-a-random-string
JWT_SECRET=change-me-to-a-random-jwt-secret

# ── Pipeline-specific ────────────────────────────────────────────
# Your admin user's MongoDB ObjectId — used to attribute scraped manga
# Find it in MongoDB Atlas → manga-reader DB → users collection
PIPELINE_USER_ID=

# Pipeline tuning (optional — these are the defaults)
# CONCURRENT_DOWNLOADS=5
# CLOUDINARY_BATCH_SIZE=3
# MAX_RETRIES=3
# DELAY_MIN_MS=1500
# DELAY_MAX_MS=4000
# LOG_LEVEL=debug
